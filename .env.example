# ── 실행 환경 ─────────────────────────────────────────────────
# local | databricks
ENV=local

# ── 서버 ──────────────────────────────────────────────────────
PORT=3002
RELOAD=true

# ── 시나리오 ──────────────────────────────────────────────────
SCENARIO_ID=cs-myk-v3

# ── 데이터베이스 ──────────────────────────────────────────────
DB_TYPE=duckdb
DB_PATH=roadshow_v3.duckdb

# ── MLflow ────────────────────────────────────────────────────
# local:       sqlite:///mlflow_v3.db
# databricks:  databricks
MLFLOW_URI=sqlite:///mlflow_v3.db
MLFLOW_ARTIFACT_ROOT=./mlruns_v3

# ── 추론 설정 ─────────────────────────────────────────────────
TOP_N_INTENT=5
INTENT_SCORE_THRESHOLD=0.05

# ── PySpark (배치 경로, 추후) ─────────────────────────────────
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=roadshow_v3
