  "event": {
    "page_field": "current_page",
    "page_default": "unknown",
    "entity_page_map": {
      "data_usage": "data",
      "billing": "billing",
      "subscription_info": "subscription",
      "benefit_membership": "benefit",
      "product_explore": "product",
      "customer_support": "support",
      "data_topup_button": "data",
      "plan_change_button": "product",
      "quality_diagnosis": "support",
      "family_bundle": "subscription",
      "penalty_calc": "churn",
      "confirm_button": "confirm",
      "coupon_use": "benefit",
      "chatbot": "support",
      "call_support": "support",
      "cancel_page": "churn"
    },
    "flags": [
      {
        "name": "is_click",
        "when": {
          "event_type_eq": "click"
        }
      },
      {
        "name": "is_page_view",
        "when": {
          "event_type_eq": "page_view"
        }
      },
      {
        "name": "is_support_entry",
        "when": {
          "event_type_eq": "support_entry"
        }
      },
      {
        "name": "is_churn_signal",
        "when": {
          "entity_in": [
            "penalty_calc",
            "cancel_page"
          ]
        }
      },
      {
        "name": "is_confirm",
        "when": {
          "entity_eq": "confirm_button"
        }
      }
    ],
    "timestamp_field": "last_event_at"
  }
