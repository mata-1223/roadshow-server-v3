{
  "_note": "L1 처리 config. pattern = 선언형 추출 spec (core/engines/extract.py가 평가). event는 미생성({}). batch_builder/preprocessing은 Phase 3 후속.",
  "preprocessing": {},
  "batch_builder": {
    "steps": [
      { "name": "_FAT", "intermediate": true, "formula": { "clamp": [0, 100], "terms": [
        { "feat": "offwork_time",  "default": 2, "linear": [1, -1], "div": 3, "mul": 50 },
        { "feat": "overtime_freq", "default": 1, "linear": [1, -1], "div": 3, "mul": 50 } ] } },
      { "name": "_ISO", "intermediate": true, "formula": { "clamp": [0, 100], "terms": [
        { "feat": "move_pattern",   "default": 1, "linear": [-1, 2], "mul": 25 },
        { "feat": "weekend_out",    "default": 2, "linear": [-1, 3], "div": 2, "mul": 35 },
        { "feat": "social_contact", "default": 3, "linear": [-1, 4], "div": 3, "mul": 40 } ] } },
      { "name": "_RETV", "intermediate": true, "formula": { "clamp": [0, 100], "terms": [
        { "feat": "plan_tier",    "default": 2, "linear": [-1, 5], "div": 4, "mul": 60 },
        { "feat": "tenure_group", "default": 2, "linear": [1, -1], "div": 4, "mul": 40 } ] } },
      { "name": "_SLEEP", "intermediate": true, "formula": { "clamp": [0, 100], "terms": [
        { "feat": "night_phone_usage", "default": 1, "linear": [1, -1], "div": 2, "mul": 70 },
        { "feat": "offwork_time",      "default": 2, "linear": [1, -1], "div": 3, "mul": 30 } ] } },

      { "name": "Fatigue Load Index",       "round": 2, "formula": { "feat": "_FAT",   "linear": [1, 0] } },
      { "name": "Isolation Tendency Index", "round": 2, "formula": { "feat": "_ISO",   "linear": [1, 0] } },
      { "name": "Retention Value Index",    "round": 2, "formula": { "feat": "_RETV",  "linear": [1, 0] } },
      { "name": "Sleep Disturbance Index",  "round": 2, "formula": { "feat": "_SLEEP", "linear": [1, 0] } },

      { "name": "Burnout Deep Score",        "round": 2, "formula": { "terms": [
        { "feat": "_FAT", "linear": [0.4, 0] }, { "feat": "_ISO", "linear": [0.3, 0] }, { "feat": "_SLEEP", "linear": [0.3, 0] } ] } },
      { "name": "Recovery Motivation Score", "round": 2, "formula": { "terms": [
        { "feat": "_FAT", "linear": [0.6, 0] }, { "feat": "_ISO", "linear": [0.4, 0] } ] } },
      { "name": "Digital Escape Score",      "round": 2, "formula": { "terms": [
        { "feat": "_SLEEP", "linear": [0.7, 0] }, { "feat": "_ISO", "linear": [0.3, 0] } ] } }
    ]
  },
  "pattern": {
    "window_seconds": 300,
    "filter": { "include": ["app_open"] },
    "fields": [
      { "name": "launch_entity_count_5m",     "source": "distinct_entity" },
      { "name": "action_intensity_5m",        "source": "total" },
      { "name": "dominant_entity_5m",          "source": "dominant_entity" },
      { "name": "entity_transition_pattern",   "source": "recent_join", "field": "entity", "n": 3 },
      { "name": "last_entity",                 "source": "last_entity" }
    ]
  },
  "event": {}
}
